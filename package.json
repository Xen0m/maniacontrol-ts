{
  "name": "maniacontrol-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Modern TypeScript controller for ManiaPlanet dedicated servers",
  "scripts": {
    "dev": "tsx src/index.ts --config maniacontrol.local.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js --config maniacontrol.local.json",
    "mx:search": "tsx src/cli/import-smx-map.ts search",
    "mx:import": "tsx src/cli/import-smx-map.ts import",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-xml-parser": "^5.3.1",
    "pino": "^9.9.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
