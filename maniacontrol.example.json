{
  "server": {
    "host": "127.0.0.1",
    "port": 5000,
    "user": "SuperAdmin",
    "password": "change-me"
  },
  "controller": {
    "apiVersion": "2013-04-16",
    "scriptApiVersion": "2.5.0",
    "enableCallbacks": true,
    "pollIntervalMs": 100,
    "logLevel": "info"
  },
  "admin": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 3001,
    "token": "replace-with-a-strong-token",
    "principals": [
      {
        "id": "observer-ui",
        "label": "Observer UI",
        "role": "observer",
        "token": "replace-with-a-readonly-token",
        "scopes": [
          "read",
          "audit.read"
        ]
      },
      {
        "id": "operator-ui",
        "label": "Operator UI",
        "role": "operator",
        "token": "replace-with-an-operator-token",
        "scopes": [
          "read",
          "audit.read",
          "players.write",
          "maps.write",
          "elite.write",
          "chat.write",
          "mode.write",
          "mx.write"
        ]
      }
    ],
    "auditPath": "./data/admin-audit.jsonl",
    "chatLoggingEnabled": false
  },
  "storage": {
    "driver": "sqlite",
    "url": "./data/maniacontrol.sqlite"
  },
  "plugins": [
    {
      "id": "server-info",
      "enabled": true
    },
    {
      "id": "shootmania-elite",
      "enabled": false,
      "settings": {
        "historyLimit": 20,
        "logTurns": true,
        "logStateSnapshots": false,
        "autoPauseEnabled": false,
        "showWidget": true
      }
    },
    {
      "id": "maniaexchange",
      "enabled": false,
      "settings": {
        "mapsDirectory": "./server/UserData/Maps/My Maps/SMX",
        "targetRelativeDirectory": "My Maps\\SMX",
        "importOnStartIds": [],
        "insertMode": "add",
        "announceImports": true,
        "showWidget": true,
        "searchLimit": 6,
        "defaultQuery": "elite"
      }
    }
  ]
}
