{
  "server": {
    "host": "127.0.0.1",
    "port": 5000,
    "user": "SuperAdmin",
    "password": "change-me"
  },
  "controller": {
    "apiVersion": "2013-04-16",
    "scriptApiVersion": "2.5.0",
    "enableCallbacks": true,
    "pollIntervalMs": 100,
    "logLevel": "info"
  },
  "admin": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 3001,
    "serverFilesRoot": "./server",
    "token": "replace-with-a-strong-token",
    "principals": [
      {
        "id": "observer-ui",
        "label": "Observer UI",
        "role": "observer",
        "token": "replace-with-a-readonly-token",
        "scopes": [
          "read",
          "audit.read"
        ]
      },
      {
        "id": "operator-ui",
        "label": "Operator UI",
        "role": "operator",
        "token": "replace-with-an-operator-token",
        "scopes": [
          "read",
          "audit.read",
          "players.write",
          "players.sanctions.read",
          "players.sanctions.write",
          "maps.write",
          "elite.write",
          "chat.write",
          "votes.write",
          "mode.write",
          "mx.write"
        ]
      }
    ],
    "modePresets": [
      {
        "id": "elite",
        "label": "ElitePro",
        "description": "Example preset based on the ElitePro script and a local matchsettings file.",
        "scriptName": "ShootMania\\Elite\\ElitePro.Script.txt",
        "matchSettings": "MatchSettings/elitepro-maps-test.txt",
        "restartAfterApply": true
      },
      {
        "id": "practice",
        "label": "Practice",
        "description": "Example practice preset using ElitePro script settings. Validate the exact flags on your server.",
        "scriptName": "ShootMania\\Elite\\ElitePro.Script.txt",
        "modeSettings": {
          "S_Mode": 1
        },
        "restartAfterApply": true
      },
      {
        "id": "duel-elite",
        "label": "Duel Elite",
        "description": "Example 1v1 ElitePro preset. Validate the exact mode settings on your server.",
        "scriptName": "ShootMania\\Elite\\ElitePro.Script.txt",
        "modeSettings": {
          "S_Mode": 0,
          "S_NbPlayersPerTeamMin": 1,
          "S_NbPlayersPerTeamMax": 1
        },
        "restartAfterApply": true
      },
      {
        "id": "instadm",
        "label": "InstaDM",
        "description": "Free-for-all InstaDM preset. Install InstaDM.Script.txt on the dedicated server before applying it.",
        "scriptName": "ShootMania\\InstaDM.Script.txt",
        "modeSettings": {
          "S_TimeLimit": 600,
          "S_PointsLimit": 50,
          "S_WeaponNumber": 2,
          "S_ArmorMax": 1,
          "S_AmmoMax": 1,
          "S_AmmoGain": 1,
          "S_Beta2Gameplay": false,
          "S_FillUpBots": 0
        },
        "restartAfterApply": true
      }
    ],
    "auditPath": "./data/admin-audit.jsonl",
    "activityPath": "./data/admin-activity.jsonl",
    "localRecordsPath": "./data/local-records.json",
    "chatLoggingEnabled": false
  },
  "storage": {
    "driver": "sqlite",
    "url": "./data/maniacontrol.sqlite"
  },
  "plugins": [
    {
      "id": "server-info",
      "enabled": true
    },
    {
      "id": "shootmania-elite",
      "enabled": false,
      "settings": {
        "historyLimit": 20,
        "logTurns": true,
        "logStateSnapshots": false,
        "autoPauseEnabled": false,
        "showWidget": false
      }
    },
    {
      "id": "maniaexchange",
      "enabled": false,
      "settings": {
        "mapsDirectory": "./server/UserData/Maps/My Maps/SMX",
        "targetRelativeDirectory": "My Maps\\SMX",
        "importOnStartIds": [],
        "insertMode": "add",
        "announceImports": true,
        "showWidget": false,
        "searchLimit": 6,
        "defaultQuery": "elite"
      }
    },
    {
      "id": "sample-external",
      "module": "./plugins/sample-external-plugin.mjs",
      "enabled": false,
      "settings": {
        "exampleFlag": true
      }
    }
  ]
}
